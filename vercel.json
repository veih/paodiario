{
    "version": 2,
    "builds": [
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "routes": [
        {
            "src": "/data/(.*)",
            "dest": "/data/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}