{
    "buildCommand": "node build.mjs",
    "outputDirectory": "dist",
    "installCommand": "npm install",
    "framework": null,
    "functions": {
        "api/**/*.ts": {
            "includeFiles": "node_modules/.prisma/client/**"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        }
    ]
}